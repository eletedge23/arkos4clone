+
+inline bool isChineseLocale() {
+    static int cached = -1;
+    if (cached == -1) {
+        setlocale(LC_ALL, "");
+        const char* locale = setlocale(LC_ALL, nullptr);
+        if (locale == nullptr || strcmp(locale, "C") == 0 || strcmp(locale, "POSIX") == 0)
+            locale = getenv("LANG");
+        cached = (locale != nullptr && strstr(locale, "zh") != nullptr) ? 1 : 0;
+    }
+    return cached == 1;
+}
+
+inline const char* tr(const char* english) {
+    if (!isChineseLocale())
+        return english;
+    auto it = translations.find(english);
+    if (it != translations.end())
+        return it->second.zh;
+    return english;
+}
